{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "outDir": "./dist",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@opengrade/fhir": ["../../packages/fhir/src"],
      "@opengrade/ui": ["../../packages/ui/src"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
