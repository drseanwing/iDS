# ==========================
# OpenGRADE Environment
# ==========================

# --- General ---
NODE_ENV=development
LOG_LEVEL=debug

# --- API Server ---
PORT=3000
CORS_ORIGIN=http://localhost:5173

# --- Database ---
# In production, append pool params to DATABASE_URL:
#   ?connection_limit=10&pool_timeout=30&connect_timeout=5
# connection_limit: max Prisma pool per process. Tune to num_cpus*2+1, and keep
#   (connection_limit * replicas) <= Postgres max_connections.
# pool_timeout: seconds to wait for a free connection before throwing P2024.
# connect_timeout: seconds to wait for initial TCP + auth handshake.
DATABASE_URL=postgresql://opengrade:opengrade@localhost:5432/opengrade?connection_limit=10&pool_timeout=30&connect_timeout=5

# --- Keycloak (OIDC) ---
# KEYCLOAK_URL and KEYCLOAK_REALM are REQUIRED in production; if unset in
# development the API falls back to unsafe token decoding with a warning.
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=opengrade
KEYCLOAK_CLIENT_ID=opengrade-api
KEYCLOAK_CLIENT_SECRET=
# Expected JWT `aud` claim. If unset, audience is not enforced (issuer +
# signature + expiry are still verified). Set to e.g. `account` or your
# client id if Keycloak emits a specific audience you want to require.
AUTH_EXPECTED_AUDIENCE=

# --- Object Storage (S3 / MinIO) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=opengrade

# --- Terminology (BioPortal) ---
# BIOPORTAL_API_KEY is required in production; if unset, the TerminologyService
# falls back to an in-memory stub dataset (with a logged warning) so the dev
# workflow still works offline. Get a key at https://bioportal.bioontology.org/.
# The in-process LRU cache caps at TERMINOLOGY_CACHE_MAX_ENTRIES and entries
# expire after TERMINOLOGY_CACHE_TTL_MS. For multi-replica deployments the
# cache should be swapped for Redis (see TODO in terminology.service.ts).
BIOPORTAL_API_KEY=
BIOPORTAL_BASE_URL=https://data.bioontology.org
TERMINOLOGY_CACHE_TTL_MS=86400000
TERMINOLOGY_CACHE_MAX_ENTRIES=1000

# --- Frontend (Vite) ---
VITE_API_URL=http://localhost:3000/api
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=opengrade
VITE_KEYCLOAK_CLIENT_ID=opengrade-web
