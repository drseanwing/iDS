# ==========================
# OpenGRADE Environment
# ==========================

# --- General ---
NODE_ENV=development
LOG_LEVEL=debug

# --- API Server ---
PORT=3000
CORS_ORIGIN=http://localhost:5173

# --- Database ---
DATABASE_URL=postgresql://opengrade:opengrade@localhost:5432/opengrade

# --- Keycloak (OIDC) ---
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=opengrade
KEYCLOAK_CLIENT_ID=opengrade-api
KEYCLOAK_CLIENT_SECRET=

# --- Object Storage (S3 / MinIO) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=opengrade

# --- Frontend (Vite) ---
VITE_API_URL=http://localhost:3000/api
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=opengrade
VITE_KEYCLOAK_CLIENT_ID=opengrade-web
